{
  "manifest_version": 3,
  "name": "Workbar - Image Staging & Drag-and-Drop Organizer",
  "version": "1.0.1",
  "description": "Stage, organize, and drag-and-drop images across the web. Eliminate the download-upload loop with a powerful sidebar workspace.",
  "permissions": ["sidePanel", "storage", "downloads", "activeTab", "tabs", "clipboardRead"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Workbar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "all_frames": true
    }
  ]
}
