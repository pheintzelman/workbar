{
  "manifest_version": 3,
  "name": "Workbar",
  "version": "1.0.0",
  "description": "Image staging area with drag-and-drop and copy-paste support.",
  "permissions": ["sidePanel", "storage", "downloads", "activeTab", "tabs"],
  "icons": {
    "16": "src/assets/icon16.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "action": {
    "default_title": "Open Workbar",
    "default_icon": {
      "16": "src/assets/icon16.png",
      "48": "src/assets/icon48.png",
      "128": "src/assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "all_frames": true
    }
  ]
}
